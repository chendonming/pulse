# ===== Reasonix 项目配置示例 =====
# 复制此文件为 reasonix.toml 并根据需要修改。
# reasonix.toml 已加入 .gitignore，不会提交到仓库。

config_version = 3
default_model = "deepseek-flash"

[agent]
temperature = 0.0
soft_compact_ratio = 0.5
tool_result_snip_ratio = 0.6
compact_ratio = 0.8
compact_force_ratio = 0.9
cold_resume_prune = true

[tools]
enabled = []
bash_timeout_seconds = 120
mcp_call_timeout_seconds = 300

[tools.background_jobs]
stalled_warning_seconds = 900

[lsp]
enabled = true

[permissions]
mode = "ask"

[sandbox]
bash = "enforce"
network = true

# MCP 插件配置
# ${VAR} 会从环境变量中展开

[[plugins]]
name    = "codegraph"
command = "codegraph"
args    = ["serve", "--mcp", "--path", "${PWD}"]
